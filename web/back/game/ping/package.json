{
  "private": true,
  "name": "my-app",
  "version": "0.17.0",
  "description": "npm init template for bootstrapping an empty Colyseus project",
  "type": "module",
  "main": "build/index.js",
  "engines": {
    "node": ">= 20.9.0"
  },
  "scripts": {
    "start": "tsx watch src/index.ts",
    "loadtest": "tsx loadtest/example.ts --room my_room --numClients 2",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rimraf build",
    "test": "mocha -r tsx test/**.test.ts --exit --timeout 15000",
    "schema-codegen": "npx schema-codegen src/rooms/schema/* --ts --output ../../front/src/game/schema"
  },
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/colyseus/create-colyseus/issues"
  },
  "homepage": "https://github.com/colyseus/create-colyseus#readme",
  "devDependencies": {
    "@colyseus/loadtest": "^0.17.7",
    "@colyseus/sdk": "^0.17.17",
    "@colyseus/testing": "^0.17.10",
    "@types/express": "^4.17.1",
    "@types/mocha": "^10.0.1",
    "mocha": "^11.7.5",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.4",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "dotenv": "^17.2.3",
    "express-session": "^1.19.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.37",
    "mysql2": "^3.16.0",
    "nodemailer": "^6.9.0",
    "otplib": "^12.0.1",
    "qrcode": "1.5.4",
    "sequelize": "^6.37.1",
    "validator": "^13.15.26",
    "ws": "^8.16.0",
    "@babylonjs/core": "^8.53.1",
    "@babylonjs/havok": "^1.3.11",
    "@colyseus/schema": "^4.0.16",
    "@colyseus/tools": "^0.17.0",
    "colyseus": "^0.17.6",
    "express": "^4.18.2",
    "tsx": "^4.21.0"
  }
}
