GameMorp.belongsTo(User, { foreignKey: 'winner', as: 'winnerUser' });

// User.hasMany(GameMorp, { foreignKey: 'loser', as: 'gamesLost', onDelete: 'CASCADE' });
GameMorp.belongsTo(User, { foreignKey: 'loser', as: 'loserUser' });

export default GameMorp;


