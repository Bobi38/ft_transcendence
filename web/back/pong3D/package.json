{
  "private": true,
  "name": "my-app",
  "version": "0.17.0",
  "description": "npm init template for bootstrapping an empty Colyseus project",
  "type": "module",
  "main": "build/index.js",
  "engines": {
    "node": ">= 20.9.0"
  },
  "scripts": {
    "start": "node build/index.js",
    "dev": "tsx watch src/index.ts",
    "loadtest": "tsx loadtest/example.ts --room my_room --numClients 2",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "clean": "rimraf build",
    "test": "mocha -r tsx test/**.test.ts --exit --timeout 15000",
    "schema-codegen": "npx schema-codegen src/rooms/schema/* --ts --output ../../front/src/game/schema"
  },
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/colyseus/create-colyseus/issues"
  },
  "homepage": "https://github.com/colyseus/create-colyseus#readme",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/mocha": "^10.0.1",
    "mocha": "^11.7.5",
    "typescript": "^5.0.4",
	"zod": "^4.3.6"
  },
  "dependencies": {
    "@babylonjs/core": "^8.53.1",
    "@colyseus/schema": "^4.0.18",
    "@colyseus/tools": "^0.17.0",
    "bcrypt": "^5.1.1",
    "colyseus": "^0.17.6",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
	"mysql2": "^3.16.0",
    "sequelize": "^6.37.1",
    "tsx": "^4.21.0"
  }
}
